@model IEnumerable<Course>
@{
    ViewData["Title"] = "Daftar Kursus";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var levels = new[] { "Pemula", "Menengah", "Lanjutan", "Semua" };
    string activeCategory = ViewBag.Category as string ?? "all";
    string activeLevel = ViewBag.Level as string ?? "all";
    string activeSort = ViewBag.Sort as string ?? "newest";
}

<section class="page-header">
    <div class="container">
        <h1>Kursus Tersedia</h1>
        <p class="text-muted">Temukan kursus yang tepat untuk pengembangan dirimu</p>
    </div>
</section>

<section class="course-index-section">
    <div class="container">
        <div class="course-index-layout">

            <!-- Filter Sidebar -->
            <aside class="filter-sidebar">
                <form method="get" id="filterForm">
                    <!-- Search -->
                    <div class="filter-group">
                        <label class="filter-label">Cari Kursus</label>
                        <div class="search-input-wrap">
                            <input type="text" name="search" value="@ViewBag.Search"
                                   placeholder="Judul, deskripsi..." class="form-control" />
                        </div>
                    </div>

                    <!-- Category -->
                    @if (categories.Any())
                    {
                        <div class="filter-group">
                            <label class="filter-label">Kategori</label>
                            <div class="chip-group">
                                <label class="chip @(activeCategory == "all" ? "chip-active" : "")">
                                    <input type="radio" name="category" value="all"
                                           @(activeCategory == "all" ? "checked" : "")
                                           onchange="this.form.submit()" hidden />
                                    Semua
                                </label>
                                @foreach (var cat in categories)
                                {
                                    <label class="chip @(activeCategory == cat ? "chip-active" : "")">
                                        <input type="radio" name="category" value="@cat"
                                               @(activeCategory == cat ? "checked" : "")
                                               onchange="this.form.submit()" hidden />
                                        @cat
                                    </label>
                                }
                            </div>
                        </div>
                    }

                    <!-- Level -->
                    <div class="filter-group">
                        <label class="filter-label">Tingkat</label>
                        <div class="chip-group">
                            <label class="chip @(activeLevel == "all" ? "chip-active" : "")">
                                <input type="radio" name="level" value="all"
                                       @(activeLevel == "all" ? "checked" : "")
                                       onchange="this.form.submit()" hidden />
                                Semua
                            </label>
                            @foreach (var lv in levels)
                            {
                                <label class="chip @(activeLevel == lv ? "chip-active" : "")">
                                    <input type="radio" name="level" value="@lv"
                                           @(activeLevel == lv ? "checked" : "")
                                           onchange="this.form.submit()" hidden />
                                    @lv
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Sort -->
                    <div class="filter-group">
                        <label class="filter-label">Urutkan</label>
                        <select name="sort" class="form-control" onchange="this.form.submit()">
                            <option value="newest" @(activeSort == "newest" ? "selected" : "")>Terbaru</option>
                            <option value="oldest" @(activeSort == "oldest" ? "selected" : "")>Terlama</option>
                            <option value="popular" @(activeSort == "popular" ? "selected" : "")>Terpopuler</option>
                            <option value="rating" @(activeSort == "rating" ? "selected" : "")>Rating Tertinggi</option>
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(ViewBag.Search as string) || activeCategory != "all" || activeLevel != "all")
                    {
                        <a asp-action="Index" class="btn btn-outline btn-block" style="margin-top:.5rem">Reset Filter</a>
                    }
                </form>
            </aside>

            <!-- Course Grid -->
            <div class="course-main">
                @if (!Model.Any())
                {
                    <div class="empty-state">
                        <div style="font-size:3rem;margin-bottom:1rem">📚</div>
                        <h3>Tidak ada kursus ditemukan</h3>
                        <p class="text-muted">Coba ubah filter atau kata kunci pencarian.</p>
                        <a asp-action="Index" class="btn btn-primary" style="margin-top:1rem">Lihat Semua Kursus</a>
                    </div>
                }
                else
                {
                    <div class="result-bar">
                        <span class="result-count">@Model.Count() kursus ditemukan</span>
                        @if (User.IsInRole("instructor") || User.IsInRole("admin"))
                        {
                            <a asp-action="Create" class="btn btn-primary btn-sm">+ Buat Kursus</a>
                        }
                    </div>
                    <div class="course-grid">
                        @foreach (var course in Model)
                        {
                            var avgRating = course.Reviews.Any() ? course.Reviews.Average(r => r.Rating) : 0;
                            var reviewCount = course.Reviews.Count;
                            var enrollCount = course.Enrollments.Count;
                            <div class="course-card">
                                <!-- Thumbnail placeholder -->
                                <div class="course-thumbnail">
                                    <span class="course-thumb-icon">📖</span>
                                    @if (!string.IsNullOrEmpty(course.Category))
                                    {
                                        <span class="course-badge badge-category">@course.Category</span>
                                    }
                                </div>
                                <div class="course-card-body">
                                    <div class="course-card-meta-top">
                                        <span class="badge badge-level">@course.Level</span>
                                    </div>
                                    <h3 class="course-card-title">@course.Title</h3>
                                    <p class="course-card-desc">@(course.Description.Length > 100 ? course.Description[..100] + "…" : course.Description)</p>
                                    <div class="course-instructor">
                                        <span class="instructor-avatar">👤</span>
                                        <span>@course.InstructorName</span>
                                    </div>

                                    <!-- Star Rating Row -->
                                    <div class="course-rating-row">
                                        @if (reviewCount > 0)
                                        {
                                            <span class="rating-score">@avgRating.ToString("0.0")</span>
                                            <div class="stars-display">
                                                @for (int s = 1; s <= 5; s++)
                                                {
                                                    <span class="star @(s <= Math.Round(avgRating) ? "filled" : "")">★</span>
                                                }
                                            </div>
                                            <span class="rating-count">(@reviewCount)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:.8rem">Belum ada ulasan</span>
                                        }
                                        <span class="enroll-count">👥 @enrollCount</span>
                                    </div>
                                </div>
                                <div class="course-card-footer">
                                    <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-primary btn-sm btn-block">
                                        Lihat Detail
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
