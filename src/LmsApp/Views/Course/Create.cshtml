@model CourseCreateViewModel
@{
    ViewData["Title"] = "Buat Kursus Baru";
}

<section class="form-page">
    <div class="container">
        <div class="form-card">
            <h1>Buat Kursus Baru</h1>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Title" class="form-label">Judul Kursus</label>
                    <input asp-for="Title" class="form-control" placeholder="Contoh: Pengantar Pemrograman Web" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label">Deskripsi</label>
                    <textarea asp-for="Description" class="form-control" rows="5"
                              placeholder="Jelaskan isi kursus ini..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="IsPublished" type="checkbox" class="form-check-input" />
                        <span class="form-label">Publikasikan sekarang</span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Buat Kursus</button>
                    <a asp-action="Index" class="btn btn-outline">Batal</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
