@model CourseDetailsViewModel
@{
    ViewData["Title"] = Model.Course.Title;
}

<section class="course-detail">
    <div class="container">
        <div class="course-detail-header">
            <h1>@Model.Course.Title</h1>
            <div class="course-badges">
                @if (Model.Course.IsPublished)
                {
                    <span class="badge badge-success">Dipublikasi</span>
                }
                else
                {
                    <span class="badge badge-warning">Draft</span>
                }
            </div>
            <p class="course-description">@Model.Course.Description</p>
            <div class="course-meta">
                <span>Instruktur: <strong>@Model.Course.InstructorName</strong></span>
                <span>@Model.EnrollmentCount peserta</span>
                <span>@Model.Course.Modules.Count modul</span>
                <span>@Model.Course.Assignments.Count tugas</span>
            </div>
        </div>

        <div class="course-detail-content">
            <!-- Left: Modules -->
            <div class="course-modules">
                <h2>Materi Kursus</h2>
                @if (!Model.Course.Modules.Any())
                {
                    <p class="text-muted">Belum ada materi.</p>
                }
                else
                {
                    <ol class="module-list">
                        @foreach (var module in Model.Course.Modules)
                        {
                            <li class="module-item @(Model.IsEnrolled ? "" : "locked")">
                                <span class="module-number">@module.Order</span>
                                <span class="module-title">@module.Title</span>
                                @if (!Model.IsEnrolled)
                                {
                                    <span class="lock-icon">🔒</span>
                                }
                            </li>
                        }
                    </ol>
                }
            </div>

            <!-- Right: Enrollment Card -->
            <div class="enrollment-card">
                @if (Model.IsEnrolled)
                {
                    <div class="enrolled-badge">✓ Sudah Terdaftar</div>
                    <a asp-controller="Course" asp-action="MyCourses" class="btn btn-primary btn-block">
                        Lanjut Belajar
                    </a>
                }
                else
                {
                    <p class="enrollment-info">Daftarkan diri Anda untuk mengakses semua materi.</p>
                    <form asp-action="Enroll" asp-route-id="@Model.Course.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary btn-block">
                            Daftar Sekarang (Gratis)
                        </button>
                    </form>
                }

                <div class="course-includes">
                    <h4>Termasuk:</h4>
                    <ul>
                        <li>@Model.Course.Modules.Count materi pembelajaran</li>
                        <li>@Model.Course.Assignments.Count tugas</li>
                        <li>Akses seumur hidup</li>
                        <li>Sertifikat penyelesaian</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Assignments -->
        @if (Model.Course.Assignments.Any() && (Model.IsEnrolled || User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin")))
        {
            bool isInstr = User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin");
            <div class="assignments-section">
                <h2>Tugas</h2>
                <div class="assignment-list">
                    @foreach (var assignment in Model.Course.Assignments)
                    {
                        bool isOverdue = assignment.DueDate.HasValue && DateTime.UtcNow > assignment.DueDate.Value;
                        <div class="assignment-card">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:.5rem">
                                <div>
                                    <h4>@assignment.Title</h4>
                                    <p>@assignment.Description</p>
                                    @if (assignment.DueDate.HasValue)
                                    {
                                        <span class="due-date" style="color:@(isOverdue ? "var(--danger)" : "inherit")">
                                            Tenggat: @assignment.DueDate.Value.ToString("dd MMM yyyy, HH:mm")
                                            @if (isOverdue) { <strong> (Terlambat)</strong> }
                                        </span>
                                    }
                                    <div class="text-muted" style="font-size:.8rem;margin-top:.25rem">Nilai maksimum: @assignment.MaxScore</div>
                                </div>
                                <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                                    @if (isInstr)
                                    {
                                        <a asp-controller="Submission" asp-action="Grade" asp-route-assignmentId="@assignment.Id"
                                           class="btn btn-sm btn-outline">📋 Lihat Submission</a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Submission" asp-action="Submit" asp-route-assignmentId="@assignment.Id"
                                           class="btn btn-sm btn-primary">📤 Kumpulkan</a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Announcement Link -->
        @if (Model.IsEnrolled || User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin"))
        {
            <div style="margin-top:1.5rem;padding:1.25rem;background:var(--white);border:1px solid var(--border);border-radius:12px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.75rem">
                <div>
                    <h3 style="margin:0 0 .25rem">📢 Pengumuman</h3>
                    <p class="text-muted" style="margin:0;font-size:.85rem">Informasi terbaru dari instruktur</p>
                </div>
                <div style="display:flex;gap:.5rem;flex-wrap:wrap">
                    @if (User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin"))
                    {
                        <a asp-controller="Announcement" asp-action="Create" asp-route-courseId="@Model.Course.Id" class="btn btn-primary btn-sm">+ Buat</a>
                    }
                    <a asp-controller="Announcement" asp-action="Course" asp-route-courseId="@Model.Course.Id" class="btn btn-outline btn-sm">Lihat Semua</a>
                </div>
            </div>
        }

        <!-- Forum Link -->
        @if (Model.IsEnrolled || User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin"))
        {
            <div style="margin-top:2rem;padding:1.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:12px">
                <h3 style="margin:0 0 .5rem">💬 Forum Diskusi</h3>
                <p class="text-muted" style="margin:0 0 1rem;font-size:.9rem">Ajukan pertanyaan dan diskusi bersama peserta lain.</p>
                <a asp-controller="Forum" asp-action="Index" asp-route-courseId="@Model.Course.Id" class="btn btn-outline">
                    Buka Forum
                </a>
            </div>
        }

        <!-- Rating & Review Section -->
        <div class="review-section" style="margin-top:2rem">
            <h2>Ulasan Kursus</h2>

            @{
                double? avgRating = ViewBag.AvgRating as double?;
                int reviewCount = (int)(ViewBag.ReviewCount ?? 0);
            }

            @if (reviewCount > 0)
            {
                <div class="review-summary">
                    <div class="review-avg-score">@(avgRating?.ToString("0.0"))</div>
                    <div>
                        <div class="stars-display lg">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span class="star @(s <= Math.Round(avgRating ?? 0) ? "filled" : "")">★</span>
                            }
                        </div>
                        <div class="text-muted" style="font-size:.85rem">@reviewCount ulasan</div>
                    </div>
                </div>
            }

            <!-- Write/Edit Review (enrolled users only) -->
            @if (Model.IsEnrolled)
            {
                var existing = ViewBag.UserReview as LmsApp.Models.CourseReview;
                <div class="review-form-card">
                    <h4>@(existing != null ? "Edit Ulasanmu" : "Tulis Ulasan")</h4>
                    <form asp-controller="Review" asp-action="Submit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courseId" value="@Model.Course.Id" />

                        <div class="star-picker" id="starPicker">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span class="star-pick @(existing != null && s <= existing.Rating ? "picked" : "")"
                                      data-val="@s">★</span>
                            }
                        </div>
                        <input type="hidden" name="rating" id="ratingInput" value="@(existing?.Rating ?? 3)" />

                        <textarea name="comment" class="form-control" rows="3" placeholder="Ceritakan pengalamanmu..." style="margin-top:.75rem">@(existing?.Comment)</textarea>

                        <div style="margin-top:.75rem;display:flex;gap:.5rem;flex-wrap:wrap">
                            <button type="submit" class="btn btn-primary btn-sm">
                                @(existing != null ? "Perbarui Ulasan" : "Kirim Ulasan")
                            </button>
                            @if (existing != null)
                            {
                                <form asp-controller="Review" asp-action="Delete" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@existing.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Hapus ulasan?')">Hapus</button>
                                </form>
                            }
                        </div>
                    </form>
                </div>
            }

            <!-- Review List -->
            @if (Model.Course.Reviews.Any())
            {
                <div class="review-list" style="margin-top:1.5rem">
                    @foreach (var review in Model.Course.Reviews)
                    {
                        <div class="review-card">
                            <div class="review-header">
                                <span class="review-author">@review.UserName</span>
                                <div class="stars-display sm">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <span class="star @(s <= review.Rating ? "filled" : "")">★</span>
                                    }
                                </div>
                                <span class="text-muted" style="font-size:.78rem">@review.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="review-comment">@review.Comment</p>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted" style="margin-top:1rem">Belum ada ulasan untuk kursus ini.</p>
            }
        </div>

        <!-- Edit button for instructor -->
        @if (User.FindFirst("sub")?.Value == Model.Course.InstructorId || User.IsInRole("admin"))
        {
            <div class="instructor-actions">
                <a asp-action="Edit" asp-route-id="@Model.Course.Id" class="btn btn-outline">Edit Kursus</a>
                <a asp-controller="Module" asp-action="Manage" asp-route-courseId="@Model.Course.Id" class="btn btn-primary">Kelola Modul</a>
                <a asp-controller="Assignment" asp-action="Manage" asp-route-courseId="@Model.Course.Id" class="btn btn-outline">Kelola Tugas</a>
                <a asp-controller="Quiz" asp-action="Manage" asp-route-courseId="@Model.Course.Id" class="btn btn-outline">Kelola Quiz</a>
                <a asp-controller="Analytics" asp-action="Course" asp-route-id="@Model.Course.Id" class="btn btn-outline">📊 Analitik</a>
            </div>
        }
    </div>
</section>
