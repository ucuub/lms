@model CourseCreateViewModel
@{
    ViewData["Title"] = "Edit Kursus";
    int courseId = (int)ViewBag.CourseId;
    var levelOptions = new[] { "Semua", "Pemula", "Menengah", "Lanjutan" };
}

<section class="form-page">
    <div class="container">
        <div class="form-card">
            <h1>Edit Kursus</h1>

            <form asp-action="Edit" asp-route-id="@courseId" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Title" class="form-label">Judul Kursus</label>
                    <input asp-for="Title" class="form-control" placeholder="Contoh: Pengantar Pemrograman Web" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label">Deskripsi</label>
                    <textarea asp-for="Description" class="form-control" rows="5"
                              placeholder="Jelaskan isi kursus ini..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Category" class="form-label">Kategori</label>
                        <input asp-for="Category" class="form-control" placeholder="Cth: Pemrograman, Desain, Bisnis" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Level" class="form-label">Tingkat Kesulitan</label>
                        <select asp-for="Level" class="form-control">
                            @foreach (var lv in levelOptions)
                            {
                                <option value="@lv" selected="@(Model.Level == lv ? "selected" : null)">@lv</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input asp-for="IsPublished" type="checkbox" class="form-check-input" />
                        <span class="form-label">Publikasikan kursus</span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
                    <a asp-action="Details" asp-route-id="@courseId" class="btn btn-outline">Batal</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
