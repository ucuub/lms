@model IEnumerable<LmsApp.Models.Announcement>
@{
    var course = ViewBag.Course as LmsApp.Models.Course;
    bool isInstructor = User.IsInRole("instructor") || User.IsInRole("admin");
    ViewData["Title"] = $"Pengumuman — {course!.Title}";
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id">← Kembali ke Kursus</a>
        <h1>📢 Pengumuman</h1>
        <p class="text-muted">@course.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:860px">

    @if (isInstructor)
    {
        <div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
            <a asp-action="Create" asp-route-courseId="@course.Id" class="btn btn-primary">+ Buat Pengumuman</a>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="forum-empty">
            <p style="font-size:2rem">📢</p>
            <p>Belum ada pengumuman untuk kursus ini.</p>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:1rem">
            @foreach (var ann in Model)
            {
                <div class="announcement-card @(ann.IsPinned ? "pinned" : "")">
                    <div class="announcement-header">
                        <div>
                            @if (ann.IsPinned)
                            {
                                <span class="pin-badge">📌 Disematkan</span>
                            }
                            <h3 class="announcement-title">@ann.Title</h3>
                            <div class="announcement-meta">
                                <span>✍️ @ann.AuthorName</span>
                                <span>🕐 @ann.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                            </div>
                        </div>
                        @if (isInstructor)
                        {
                            <form asp-action="Delete" method="post" style="display:inline"
                                  onsubmit="return confirm('Hapus pengumuman ini?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@ann.Id" />
                                <button type="submit" class="btn btn-sm"
                                        style="background:#ef4444;color:white;border:none;align-self:flex-start">✕</button>
                            </form>
                        }
                    </div>
                    <div class="announcement-body">@ann.Content</div>
                </div>
            }
        </div>
    }
</div>
