@{
    int courseId = (int)ViewBag.CourseId;
    ViewData["Title"] = "Buat Pengumuman";
}

<section class="page-header">
    <div class="container">
        <a asp-action="Course" asp-route-courseId="@courseId">← Daftar Pengumuman</a>
        <h1>📢 Buat Pengumuman</h1>
        <p class="text-muted">Pengumuman akan dikirim ke semua peserta kursus.</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:700px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="courseId" value="@courseId" />

        <div class="form-group">
            <label class="form-label">Judul Pengumuman <span style="color:var(--danger)">*</span></label>
            <input type="text" name="title" class="form-control"
                   placeholder="Contoh: Jadwal kelas berubah minggu ini" maxlength="300" required />
        </div>

        <div class="form-group">
            <label class="form-label">Isi Pengumuman <span style="color:var(--danger)">*</span></label>
            <textarea name="content" rows="6" class="form-control" style="resize:vertical"
                      placeholder="Tulis isi pengumuman secara jelas dan lengkap..." required></textarea>
        </div>

        <div class="form-group">
            <label class="form-check">
                <input type="checkbox" name="isPinned" value="true" class="form-check-input" />
                <span class="form-label" style="margin:0">📌 Sematkan pengumuman ini di paling atas</span>
            </label>
        </div>

        <div class="alert" style="background:#eff6ff;border:1px solid #bfdbfe;color:#1e40af;padding:.85rem 1.25rem;border-radius:8px;margin-bottom:1rem;font-size:.9rem">
            🔔 Notifikasi otomatis akan dikirimkan ke semua peserta yang terdaftar di kursus ini.
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Kirim Pengumuman</button>
            <a asp-action="Course" asp-route-courseId="@courseId" class="btn btn-outline">Batal</a>
        </div>
    </form>
</div>
