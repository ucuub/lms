@model LmsApp.ViewModels.QuestionCreateViewModel
@{
    ViewData["Title"] = "Tambah Soal";
    var quiz = ViewBag.Quiz as LmsApp.Models.Quiz;
}

<section class="page-header">
    <div class="container">
        <a asp-action="Manage" asp-controller="Question" asp-route-quizId="@Model.QuizId">← Kelola Soal</a>
        <h1>Tambah Soal Baru</h1>
        <p class="text-muted">@quiz!.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:780px">

    <!-- Import CSV Card -->
    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:1.25rem;margin-bottom:2rem">
        <h3 style="font-size:.95rem;font-weight:700;color:#1e40af;margin-bottom:.5rem">⬆️ Import Soal dari CSV</h3>
        <p style="font-size:.82rem;color:#1e40af;margin-bottom:.75rem">
            Format CSV: <code>tipe,teks_soal,poin,opsi_a,opsi_b,opsi_c,opsi_d,jawaban_benar</code><br>
            Tipe: <code>mcq</code> / <code>tf</code> / <code>essay</code> · Jawaban MCQ: A/B/C/D · TF: true/false
        </p>
        <form asp-action="ImportCsv" asp-controller="Question" method="post" enctype="multipart/form-data"
              style="display:flex;gap:.5rem;flex-wrap:wrap">
            @Html.AntiForgeryToken()
            <input type="hidden" name="quizId" value="@Model.QuizId" />
            <input type="file" name="file" accept=".csv" class="form-control" style="flex:1;min-width:200px" required />
            <button type="submit" class="btn btn-outline" style="border-color:#3b82f6;color:#1e40af;white-space:nowrap">
                Import CSV
            </button>
        </form>
    </div>

    <!-- Manual Add Form -->
    <div class="form-card" style="padding:1.75rem">
        <h3 style="font-size:1rem;font-weight:700;margin-bottom:1.25rem">✏️ Tambah Soal Manual</h3>
        <form asp-action="Create" asp-controller="Question" method="post" id="question-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="QuizId" />

            <div class="form-group">
                <label class="form-label">Tipe Soal</label>
                <div style="display:flex;gap:.5rem;flex-wrap:wrap" id="type-selector">
                    <label class="type-btn active" data-val="0">
                        <input type="radio" name="Type" value="0" checked style="display:none" />
                        🔵 Pilihan Ganda
                    </label>
                    <label class="type-btn" data-val="1">
                        <input type="radio" name="Type" value="1" style="display:none" />
                        ✅ Benar / Salah
                    </label>
                    <label class="type-btn" data-val="2">
                        <input type="radio" name="Type" value="2" style="display:none" />
                        📝 Essay
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Teks Soal <span style="color:var(--danger)">*</span></label>
                <textarea asp-for="Text" class="form-control" rows="3"
                          placeholder="Tulis pertanyaan di sini..."></textarea>
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Poin</label>
                <input asp-for="Points" type="number" class="form-control"
                       style="max-width:120px" min="1" max="100" />
                <span asp-validation-for="Points" class="text-danger"></span>
            </div>

            <!-- MCQ Options -->
            <div id="options-section">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem">
                    <label class="form-label" style="margin:0">Pilihan Jawaban <small class="text-muted">(✓ = benar)</small></label>
                    <button type="button" class="btn btn-sm btn-outline" onclick="addOption()" id="add-option-btn">
                        + Tambah Pilihan
                    </button>
                </div>
                <div id="options-list">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="option-input-row" data-idx="@i">
                            <input type="checkbox" name="Options[@i].IsCorrect" value="true"
                                   class="form-check-input" title="Tandai sebagai jawaban benar" />
                            <span class="option-letter">@(char.ConvertFromUtf32(65 + i))</span>
                            <input type="text" name="Options[@i].Text" class="form-control"
                                   placeholder="Pilihan @(char.ConvertFromUtf32(65 + i))" />
                            @if (i >= 2)
                            {
                                <button type="button" class="btn btn-sm" onclick="removeOption(this)"
                                        style="background:#fee2e2;color:#b91c1c;border:none;padding:.25rem .5rem">✕</button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- True/False Options -->
            <div id="truefalse-section" style="display:none">
                <label class="form-label">Jawaban yang Benar</label>
                <div style="display:flex;gap:1rem">
                    <label class="type-btn active" style="padding:.5rem 1.25rem" id="tf-true">
                        <input type="radio" name="CorrectTrueFalse" value="true" checked style="display:none" />
                        ✓ Benar
                    </label>
                    <label class="type-btn" style="padding:.5rem 1.25rem" id="tf-false">
                        <input type="radio" name="CorrectTrueFalse" value="false" style="display:none" />
                        ✗ Salah
                    </label>
                </div>
            </div>

            <!-- Essay info -->
            <div id="essay-section" style="display:none">
                <div class="alert" style="background:#fffbeb;border:1px solid #f59e0b;color:#92400e;padding:.85rem 1.25rem;border-radius:8px">
                    📝 Soal essay dinilai secara manual oleh instruktur setelah peserta mengumpulkan.
                </div>
            </div>

            <div class="form-actions" style="margin-top:1.5rem">
                <button type="submit" class="btn btn-primary">Simpan Soal</button>
                <a asp-action="Manage" asp-controller="Question" asp-route-quizId="@Model.QuizId" class="btn btn-outline">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
// ── Type selector ─────────────────────────────────────────────────
document.querySelectorAll('#type-selector .type-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        btn.querySelector('input[type=radio]').checked = true;
        document.querySelectorAll('#type-selector .type-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateForm(btn.dataset.val);
    });
});

function updateForm(type) {
    document.getElementById('options-section').style.display = type === '0' ? 'block' : 'none';
    document.getElementById('truefalse-section').style.display = type === '1' ? 'block' : 'none';
    document.getElementById('essay-section').style.display = type === '2' ? 'block' : 'none';
}
updateForm('0');

// ── Dynamic MCQ option rows ───────────────────────────────────────
let optIdx = 4;
function addOption() {
    if (optIdx >= 8) return;
    const list = document.getElementById('options-list');
    const letter = String.fromCharCode(65 + optIdx);
    const div = document.createElement('div');
    div.className = 'option-input-row';
    div.dataset.idx = optIdx;
    div.innerHTML = `
        <input type="checkbox" name="Options[${optIdx}].IsCorrect" value="true"
               class="form-check-input" title="Tandai jawaban benar" />
        <span class="option-letter">${letter}</span>
        <input type="text" name="Options[${optIdx}].Text" class="form-control"
               placeholder="Pilihan ${letter}" />
        <button type="button" class="btn btn-sm" onclick="removeOption(this)"
                style="background:#fee2e2;color:#b91c1c;border:none;padding:.25rem .5rem">✕</button>`;
    list.appendChild(div);
    optIdx++;
    if (optIdx >= 8) document.getElementById('add-option-btn').style.display = 'none';
}

function removeOption(btn) {
    btn.closest('.option-input-row').remove();
    if (optIdx < 8) document.getElementById('add-option-btn').style.display = '';
}

// ── True/False toggle ─────────────────────────────────────────────
['tf-true','tf-false'].forEach(id => {
    document.getElementById(id)?.addEventListener('click', () => {
        document.getElementById('tf-true').classList.remove('active');
        document.getElementById('tf-false').classList.remove('active');
        document.getElementById(id).classList.add('active');
    });
});
</script>
}
