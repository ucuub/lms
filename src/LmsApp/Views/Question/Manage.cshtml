@model Quiz
@{
    ViewData["Title"] = "Kelola Soal - " + Model.Title;
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">← @Model.Course.Title</a>
        <h1>Kelola Soal: @Model.Title</h1>
        <p class="text-muted">@Model.Questions.Count soal · Total: @Model.Questions.Sum(q => q.Points) poin</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
        <div>
            <span class="badge @(Model.IsPublished ? "badge-success" : "badge-warning")">
                @(Model.IsPublished ? "Dipublikasi" : "Draft")
            </span>
        </div>
        <a asp-action="Create" asp-controller="Question" asp-route-quizId="@Model.Id" class="btn btn-primary">
            + Tambah Soal
        </a>
    </div>

    @if (!Model.Questions.Any())
    {
        <div class="empty-state">
            <p>Belum ada soal. Tambahkan soal pertama!</p>
        </div>
    }
    else
    {
        <div class="question-manage-list" id="question-list">
            @foreach (var question in Model.Questions.OrderBy(q => q.Order))
            {
                <div class="question-manage-card" data-id="@question.Id">
                    <div class="question-drag-handle">⠿</div>
                    <div class="question-manage-content">
                        <div class="question-manage-header">
                            <span class="question-order-badge">@question.Order</span>
                            <span class="badge @(question.Type == QuestionType.Essay ? "badge-warning" : question.Type == QuestionType.TrueFalse ? "badge-info" : "badge-success")">
                                @question.Type
                            </span>
                            <span class="text-muted" style="font-size:.85rem">@question.Points poin</span>
                        </div>
                        <p class="question-text" style="margin:.5rem 0 .75rem">@question.Text</p>
                        @if (question.Options.Any())
                        {
                            <ul style="list-style:none;display:flex;flex-direction:column;gap:.25rem">
                                @foreach (var opt in question.Options)
                                {
                                    <li style="font-size:.85rem;color:@(opt.IsCorrect ? "#166534" : "var(--text-muted)");font-weight:@(opt.IsCorrect ? "700" : "400")">
                                        @(opt.IsCorrect ? "✓" : "○") @opt.Text
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                    <div>
                        <form asp-action="Delete" asp-controller="Question" method="post"
                              onsubmit="return confirm('Hapus soal ini?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@question.Id" />
                            <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border-color:#ef4444">Hapus</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
