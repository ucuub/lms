@{
    var course = ViewBag.Course as LmsApp.Models.Course;
    var threads = ViewBag.Threads as dynamic;
    int page = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    bool isInstructor = (bool)ViewBag.IsInstructor;
    ViewData["Title"] = $"Forum — {course!.Title}";
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@course.Id">← Kembali ke Kursus</a>
        <h1>💬 Forum Diskusi</h1>
        <p class="text-muted">@course.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:900px">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
        <p class="text-muted" style="margin:0">Tanya, diskusi, dan bantu sesama peserta kursus.</p>
        <a asp-action="Create" asp-route-courseId="@course.Id" class="btn btn-primary">+ Buat Diskusi</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (threads == null || ((IEnumerable<dynamic>)threads).Count() == 0)
    {
        <div class="forum-empty">
            <p style="font-size:2rem">💬</p>
            <p>Belum ada diskusi. Jadilah yang pertama bertanya!</p>
            <a asp-action="Create" asp-route-courseId="@course.Id" class="btn btn-primary" style="margin-top:.75rem">Mulai Diskusi</a>
        </div>
    }
    else
    {
        <div class="forum-thread-list">
            @foreach (var t in (IEnumerable<dynamic>)threads)
            {
                <div class="forum-thread-item @(t.IsPinned ? "pinned" : "")">
                    @if (t.IsPinned)
                    {
                        <span class="pin-badge">📌 Disematkan</span>
                    }
                    <a asp-action="Thread" asp-route-id="@t.Id" class="thread-title">@t.Title</a>
                    <div class="thread-meta">
                        <span>👤 @t.UserName</span>
                        <span>🕐 @((DateTime)t.CreatedAt).ToString("dd MMM yyyy, HH:mm")</span>
                        <span class="reply-count">💬 @t.ReplyCount balasan</span>
                    </div>
                    @if (isInstructor)
                    {
                        <form asp-action="Pin" method="post" style="display:inline;margin-top:.35rem">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm btn-outline" style="font-size:.75rem;padding:.2rem .6rem">
                                @(t.IsPinned ? "Lepas Pin" : "📌 Sematkan")
                            </button>
                        </form>
                        <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Hapus thread ini?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border:none;font-size:.75rem;padding:.2rem .6rem">Hapus</button>
                        </form>
                    }
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="pagination" style="margin-top:1.5rem">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a asp-action="Index" asp-route-courseId="@course.Id" asp-route-page="@i"
                       class="btn @(i == page ? "btn-primary" : "btn-outline")" style="padding:.4rem .8rem">@i</a>
                }
            </div>
        }
    }
</div>
