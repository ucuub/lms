@model LmsApp.Models.ForumPost
@{
    bool isInstructor = (bool)ViewBag.IsInstructor;
    string currentUserId = (string)ViewBag.UserId;
    ViewData["Title"] = Model.Title;
}

<section class="page-header">
    <div class="container">
        <a asp-action="Index" asp-route-courseId="@Model.CourseId">← Forum @Model.Course.Title</a>
        <h1>@Model.Title</h1>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:900px">

    <!-- Original Thread Post -->
    <div class="forum-post forum-post-thread">
        <div class="post-avatar">@Model.UserName[0]</div>
        <div class="post-body">
            <div class="post-header">
                <strong>@Model.UserName</strong>
                @if (Model.IsPinned) { <span class="pin-badge">📌</span> }
                <span class="text-muted" style="font-size:.8rem">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="post-content">@Model.Body</div>
            <div class="post-actions">
                @if (Model.UserId == currentUserId || isInstructor)
                {
                    <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Hapus diskusi ini? Semua balasan akan tersembunyi.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border:none;font-size:.78rem">Hapus</button>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Replies -->
    @if (Model.Replies.Any())
    {
        <div class="forum-replies">
            <h3 style="font-size:1rem;color:var(--text-muted);margin-bottom:1rem">@Model.Replies.Count Balasan</h3>
            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedAt))
            {
                <div class="forum-post forum-post-reply">
                    <div class="post-avatar post-avatar-sm">@reply.UserName[0]</div>
                    <div class="post-body">
                        <div class="post-header">
                            <strong>@reply.UserName</strong>
                            <span class="text-muted" style="font-size:.78rem">@reply.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <div class="post-content">@reply.Body</div>
                        @if (reply.UserId == currentUserId || isInstructor)
                        {
                            <div class="post-actions">
                                <form asp-action="Delete" method="post" style="display:inline" onsubmit="return confirm('Hapus balasan ini?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@reply.Id" />
                                    <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border:none;font-size:.75rem;padding:.15rem .5rem">Hapus</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <!-- Reply Form -->
    <div class="forum-reply-form">
        <h3 style="font-size:1rem;font-weight:700;margin-bottom:.75rem">Tulis Balasan</h3>
        <form asp-action="Reply" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="threadId" value="@Model.Id" />
            <textarea name="body" rows="5" class="form-control"
                      placeholder="Tulis balasanmu di sini..." style="resize:vertical" required></textarea>
            <div style="margin-top:.75rem;text-align:right">
                <button type="submit" class="btn btn-primary">Kirim Balasan 💬</button>
            </div>
        </form>
    </div>

</div>
