@{
    var course = ViewBag.Course as LmsApp.Models.Course;
    ViewData["Title"] = "Buat Diskusi Baru";
}

<section class="page-header">
    <div class="container">
        <a asp-action="Index" asp-route-courseId="@course!.Id">← Forum @course.Title</a>
        <h1>💬 Buat Diskusi Baru</h1>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:700px">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="courseId" value="@course!.Id" />

        <div class="form-group">
            <label class="form-label">Judul Diskusi <span style="color:#ef4444">*</span></label>
            <input type="text" name="title" class="form-control"
                   placeholder="Contoh: Bagaimana cara memahami konsep OOP?" maxlength="300" required />
        </div>

        <div class="form-group">
            <label class="form-label">Isi Pertanyaan / Diskusi <span style="color:#ef4444">*</span></label>
            <textarea name="body" rows="8" class="form-control" style="resize:vertical"
                      placeholder="Jelaskan pertanyaan atau topikmu secara detail..." required></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Kirim Diskusi</button>
            <a asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-outline">Batal</a>
        </div>
    </form>
</div>
