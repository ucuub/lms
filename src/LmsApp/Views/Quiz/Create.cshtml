@model LmsApp.ViewModels.QuizCreateViewModel
@{
    ViewData["Title"] = "Buat Quiz Baru";
    int courseId = (int)ViewBag.CourseId;
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@courseId">← Kembali ke Kursus</a>
        <h1>📝 Buat Quiz Baru</h1>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:750px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CourseId" />

        <div class="form-group">
            <label class="form-label">Judul Quiz <span style="color:var(--danger)">*</span></label>
            <input asp-for="Title" class="form-control" placeholder="Contoh: Quiz Bab 1 — Dasar-Dasar OOP" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Deskripsi <small class="text-muted">(opsional)</small></label>
            <textarea asp-for="Description" class="form-control" rows="3"
                      placeholder="Instruksi atau keterangan tambahan untuk peserta..."></textarea>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group">
                <label class="form-label">Batas Waktu (menit)</label>
                <input asp-for="TimeLimitMinutes" type="number" class="form-control" min="5" max="180" />
                <span asp-validation-for="TimeLimitMinutes" class="text-danger"></span>
                <small class="text-muted">5 – 180 menit</small>
            </div>

            <div class="form-group">
                <label class="form-label">Maks. Percobaan</label>
                <input asp-for="MaxAttempts" type="number" class="form-control" min="1" max="10" />
                <span asp-validation-for="MaxAttempts" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Nilai Lulus (%)</label>
                <input asp-for="PassScore" type="number" class="form-control" min="0" max="100" />
                <span asp-validation-for="PassScore" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Tenggat <small class="text-muted">(opsional)</small></label>
                <input asp-for="DueDate" type="datetime-local" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-check">
                <input asp-for="IsPublished" type="checkbox" class="form-check-input" />
                <span class="form-label" style="margin:0">Publikasikan langsung</span>
            </label>
            <p class="text-muted" style="font-size:.8rem;margin-top:.25rem">
                Jika tidak dicentang, peserta belum bisa mengakses quiz ini.
            </p>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Buat Quiz & Tambah Soal →</button>
            <a asp-controller="Course" asp-action="Details" asp-route-id="@courseId" class="btn btn-outline">Batal</a>
        </div>
    </form>
</div>
