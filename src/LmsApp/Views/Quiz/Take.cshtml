@model QuizAttempt
@{
    ViewData["Title"] = "Quiz: " + Model.Quiz.Title;
    Layout = "_Layout";
}

<section class="quiz-take">
    <div class="container">
        <div class="quiz-take-header">
            <h2>@Model.Quiz.Title</h2>
            <div class="quiz-timer" id="timer">⏱ <span id="time-left">@(Model.Quiz.TimeLimitMinutes * 60)</span>s</div>
        </div>

        <form asp-action="Submit" method="post" id="quiz-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="attemptId" value="@Model.Id" />

            @for (int i = 0; i < Model.Quiz.Questions.Count; i++)
            {
                var question = Model.Quiz.Questions.OrderBy(q => q.Order).ElementAt(i);
                <div class="question-card">
                    <div class="question-number">Soal @(i + 1) <span class="badge badge-info">@question.Points poin</span></div>
                    <p class="question-text">@question.Text</p>

                    @if (question.Type == QuestionType.Essay)
                    {
                        <textarea name="essays[@question.Id]" class="form-control" rows="4"
                                  placeholder="Tulis jawaban Anda..."></textarea>
                    }
                    else
                    {
                        <div class="options-list">
                            @foreach (var option in question.Options)
                            {
                                <label class="option-label">
                                    <input type="radio" name="answers[@question.Id]" value="@option.Id" />
                                    <span>@option.Text</span>
                                </label>
                            }
                        </div>
                    }
                </div>
            }

            <div class="quiz-submit-bar">
                <button type="submit" class="btn btn-primary btn-lg"
                        onclick="return confirm('Yakin ingin mengumpulkan jawaban?')">
                    Kumpulkan Jawaban
                </button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
<script>
    let seconds = @(Model.Quiz.TimeLimitMinutes * 60);
    const display = document.getElementById('time-left');
    const timer = setInterval(() => {
        seconds--;
        const m = Math.floor(seconds / 60);
        const s = seconds % 60;
        display.textContent = `${m}:${s.toString().padStart(2, '0')}`;
        if (seconds <= 0) {
            clearInterval(timer);
            document.getElementById('quiz-form').submit();
        }
    }, 1000);
</script>
}
