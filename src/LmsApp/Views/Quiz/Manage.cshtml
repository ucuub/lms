@model LmsApp.Models.Course
@{
    ViewData["Title"] = "Kelola Quiz — " + Model.Title;
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id">← @Model.Title</a>
        <h1>📝 Kelola Quiz</h1>
        <p class="text-muted">@Model.Quizzes.Count quiz dibuat</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:900px">
    <div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
        <a asp-action="Create" asp-controller="Quiz" asp-route-courseId="@Model.Id" class="btn btn-primary">+ Buat Quiz</a>
    </div>

    @if (!Model.Quizzes.Any())
    {
        <div class="forum-empty">
            <p style="font-size:2rem">📝</p>
            <p>Belum ada quiz. Buat quiz pertama untuk kursus ini.</p>
        </div>
    }
    else
    {
        <div style="display:flex;flex-direction:column;gap:.75rem">
            @foreach (var quiz in Model.Quizzes.OrderByDescending(q => q.CreatedAt))
            {
                int attemptCount = quiz.Attempts.Count;
                int questionCount = quiz.Questions.Count;
                int totalPoints = quiz.Questions.Sum(q => q.Points);
                bool isOverdue = quiz.DueDate.HasValue && DateTime.UtcNow > quiz.DueDate.Value;

                <div style="background:white;border:1px solid var(--border);border-radius:12px;padding:1.25rem">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:.75rem">
                        <div style="flex:1">
                            <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.35rem">
                                <h3 style="font-size:1rem;font-weight:700;margin:0">@quiz.Title</h3>
                                <span class="badge @(quiz.IsPublished ? "badge-success" : "badge-warning")">
                                    @(quiz.IsPublished ? "Publik" : "Draft")
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(quiz.Description))
                            {
                                <p class="text-muted" style="font-size:.85rem;margin-bottom:.5rem">@quiz.Description</p>
                            }
                            <div style="display:flex;gap:1rem;font-size:.8rem;color:var(--text-muted);flex-wrap:wrap">
                                <span>⏱ @quiz.TimeLimitMinutes menit</span>
                                <span>❓ @questionCount soal (@totalPoints poin)</span>
                                <span>🎯 Lulus @quiz.PassScore%</span>
                                <span>🔄 Maks. @quiz.MaxAttempts percobaan</span>
                                <span>📤 @attemptCount pengerjaan</span>
                                @if (quiz.DueDate.HasValue)
                                {
                                    <span style="color:@(isOverdue ? "var(--danger)" : "inherit")">
                                        📅 @quiz.DueDate.Value.ToString("dd MMM yyyy, HH:mm")
                                        @if (isOverdue) { <strong>(Tutup)</strong> }
                                    </span>
                                }
                            </div>
                        </div>
                        <div style="display:flex;gap:.4rem;flex-wrap:wrap;flex-shrink:0">
                            <a asp-action="Manage" asp-controller="Question" asp-route-quizId="@quiz.Id"
                               class="btn btn-sm btn-primary">❓ Soal</a>
                            <a asp-action="Edit" asp-controller="Quiz" asp-route-id="@quiz.Id"
                               class="btn btn-sm btn-outline">✎ Edit</a>
                            <form asp-action="TogglePublish" asp-controller="Quiz" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@quiz.Id" />
                                <button type="submit" class="btn btn-sm btn-outline" style="font-size:.78rem">
                                    @(quiz.IsPublished ? "Sembunyikan" : "Publikasikan")
                                </button>
                            </form>
                            <form asp-action="Delete" asp-controller="Quiz" method="post" style="display:inline"
                                  onsubmit="return confirm('Hapus quiz ini? Semua pengerjaan akan terhapus.')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@quiz.Id" />
                                <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border:none">✕</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
