@model LmsApp.ViewModels.QuizCreateViewModel
@{
    ViewData["Title"] = "Edit Quiz";
    var quiz = ViewBag.Quiz as LmsApp.Models.Quiz;
}

<section class="page-header">
    <div class="container">
        <a asp-action="Manage" asp-controller="Quiz" asp-route-courseId="@Model.CourseId">← Kelola Quiz</a>
        <h1>✎ Edit Quiz</h1>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:750px">
    <form asp-action="Edit" asp-route-id="@quiz!.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CourseId" />

        <div class="form-group">
            <label class="form-label">Judul Quiz <span style="color:var(--danger)">*</span></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Deskripsi</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group">
                <label class="form-label">Batas Waktu (menit)</label>
                <input asp-for="TimeLimitMinutes" type="number" class="form-control" min="5" max="180" />
                <span asp-validation-for="TimeLimitMinutes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Maks. Percobaan</label>
                <input asp-for="MaxAttempts" type="number" class="form-control" min="1" max="10" />
                <span asp-validation-for="MaxAttempts" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Nilai Lulus (%)</label>
                <input asp-for="PassScore" type="number" class="form-control" min="0" max="100" />
                <span asp-validation-for="PassScore" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Tenggat</label>
                <input asp-for="DueDate" type="datetime-local" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-check">
                <input asp-for="IsPublished" type="checkbox" class="form-check-input" />
                <span class="form-label" style="margin:0">Publikasikan</span>
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Simpan Perubahan</button>
            <a asp-action="Manage" asp-controller="Quiz" asp-route-courseId="@Model.CourseId" class="btn btn-outline">Batal</a>
            <a asp-action="Manage" asp-controller="Question" asp-route-quizId="@quiz.Id" class="btn btn-outline">❓ Kelola Soal</a>
        </div>
    </form>
</div>
