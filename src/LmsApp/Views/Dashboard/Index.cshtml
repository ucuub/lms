@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-header">
    <div class="container">
        <h1>Dashboard</h1>
        <p class="text-muted">Selamat datang kembali, <strong>@User.Identity?.Name</strong></p>
    </div>
</section>

<div class="container dashboard-grid" style="padding: 2rem 1.5rem;">
    <!-- Kursus Aktif -->
    <div class="dashboard-main">
        <h2 class="section-title">Kursus Aktif</h2>
        @if (!Model.Enrollments.Any())
        {
            <div class="empty-state">
                <p>Belum ada kursus. <a asp-controller="Course" asp-action="Index">Jelajahi kursus</a></p>
            </div>
        }
        else
        {
            <div class="course-progress-list">
                @foreach (var enrollment in Model.Enrollments)
                {
                    var progress = Model.GetProgress(enrollment.CourseId);
                    var pct = progress?.Percentage ?? 0;
                    <div class="progress-card">
                        <div class="progress-card-info">
                            <h4>@enrollment.Course.Title</h4>
                            <p class="text-muted">@enrollment.Course.InstructorName</p>
                        </div>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @pct%"></div>
                            </div>
                            <span class="progress-label">@pct%</span>
                        </div>
                        <a asp-controller="Course" asp-action="Details" asp-route-id="@enrollment.CourseId"
                           class="btn btn-primary btn-sm">Lanjutkan</a>
                    </div>
                }
            </div>
        }

        <!-- Sertifikat -->
        @if (Model.Certificates.Any())
        {
            <h2 class="section-title" style="margin-top:2rem">Sertifikat Saya</h2>
            <div class="cert-list">
                @foreach (var cert in Model.Certificates)
                {
                    <div class="cert-card">
                        <span class="cert-icon">🏆</span>
                        <div>
                            <strong>@cert.Course.Title</strong>
                            <p class="text-muted" style="font-size:0.85rem">No. @cert.CertificateNumber</p>
                            <p class="text-muted" style="font-size:0.85rem">@cert.IssuedAt.ToString("dd MMM yyyy")</p>
                        </div>
                        <a asp-controller="Certificate" asp-action="View" asp-route-id="@cert.Id"
                           class="btn btn-outline btn-sm">Lihat</a>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Sidebar -->
    <div class="dashboard-sidebar">
        <!-- Deadline Mendatang -->
        <div class="sidebar-card">
            <h3>📅 Deadline Mendatang</h3>
            @if (!Model.UpcomingDeadlines.Any())
            {
                <p class="text-muted" style="font-size:0.9rem">Tidak ada deadline mendatang.</p>
            }
            else
            {
                <ul class="deadline-list">
                    @foreach (var ev in Model.UpcomingDeadlines)
                    {
                        <li class="deadline-item">
                            <span class="deadline-type @ev.Type.ToString().ToLower()">@ev.Type</span>
                            <div>
                                <strong>@ev.Title</strong>
                                <p>@ev.EventDate.ToString("dd MMM yyyy, HH:mm")</p>
                            </div>
                        </li>
                    }
                </ul>
            }
            <a asp-controller="Calendar" asp-action="Index" class="btn btn-outline btn-sm" style="width:100%;margin-top:1rem">Lihat Kalender</a>
        </div>

        <!-- Pengumuman Terbaru -->
        <div class="sidebar-card">
            <h3>📢 Pengumuman</h3>
            @if (!Model.RecentAnnouncements.Any())
            {
                <p class="text-muted" style="font-size:0.9rem">Tidak ada pengumuman terbaru.</p>
            }
            else
            {
                @foreach (var ann in Model.RecentAnnouncements)
                {
                    <div class="announcement-item">
                        @if (ann.IsPinned) { <span class="pin">📌</span> }
                        <strong>@ann.Title</strong>
                        <p class="text-muted" style="font-size:0.8rem">@ann.Course?.Title · @ann.CreatedAt.ToString("dd MMM")</p>
                    </div>
                }
            }
        </div>
    </div>
</div>
