@model LmsApp.Models.Assignment
@{
    var course = ViewBag.Course as LmsApp.Models.Course;
    bool isEdit = Model.Id != 0;
}

<section class="page-header">
    <div class="container">
        <a asp-action="Manage" asp-route-courseId="@course!.Id">← Kelola Tugas</a>
        <h1>@(isEdit ? "Edit Tugas" : "Tugas Baru")</h1>
        <p class="text-muted">@course.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:700px">
    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="CourseId" value="@course!.Id" />

        <div class="form-group">
            <label class="form-label">Judul Tugas <span style="color:var(--danger)">*</span></label>
            <input type="text" name="Title" value="@Model.Title" class="form-control"
                   placeholder="Contoh: Tugas 1 - Analisis Kasus" maxlength="200" required />
        </div>

        <div class="form-group">
            <label class="form-label">Deskripsi / Instruksi</label>
            <textarea name="Description" rows="5" class="form-control" style="resize:vertical"
                      placeholder="Jelaskan instruksi tugas secara detail...">@Model.Description</textarea>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div class="form-group">
                <label class="form-label">Tenggat Waktu <small class="text-muted">(opsional)</small></label>
                <input type="datetime-local" name="DueDate" class="form-control"
                       value="@Model.DueDate?.ToString("yyyy-MM-ddTHH:mm")" />
            </div>
            <div class="form-group">
                <label class="form-label">Nilai Maksimum</label>
                <input type="number" name="MaxScore" class="form-control"
                       value="@Model.MaxScore" min="1" max="1000" required />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">@(isEdit ? "Simpan Perubahan" : "Buat Tugas")</button>
            <a asp-action="Manage" asp-route-courseId="@course.Id" class="btn btn-outline">Batal</a>
        </div>
    </form>
</div>
