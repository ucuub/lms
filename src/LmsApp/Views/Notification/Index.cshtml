@model IEnumerable<Notification>
@{
    ViewData["Title"] = "Notifikasi";
}

<section class="page-header">
    <div class="container" style="display:flex;justify-content:space-between;align-items:center">
        <h1>🔔 Notifikasi</h1>
        @if (Model.Any())
        {
            <form asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline btn-sm">Tandai semua dibaca</button>
            </form>
        }
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:700px">
    @if (!Model.Any())
    {
        <div class="empty-state"><p>Tidak ada notifikasi.</p></div>
    }
    else
    {
        @foreach (var notif in Model)
        {
            <a href="@(notif.Link ?? "#")" class="notif-item @(notif.IsRead ? "" : "unread")">
                <span class="notif-icon">@(notif.Type switch {
                    NotificationType.Success => "🎉",
                    NotificationType.Grade => "📊",
                    NotificationType.Quiz => "📝",
                    NotificationType.Assignment => "📌",
                    NotificationType.Announcement => "📢",
                    NotificationType.Warning => "⚠️",
                    _ => "ℹ️"
                })</span>
                <div class="notif-content">
                    <strong>@notif.Title</strong>
                    <p>@notif.Message</p>
                    <small class="text-muted">@notif.CreatedAt.ToString("dd MMM yyyy, HH:mm")</small>
                </div>
                @if (!notif.IsRead)
                {
                    <span class="notif-dot"></span>
                }
            </a>
        }
    }
</div>
