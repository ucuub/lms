@model Course
@{
    ViewData["Title"] = "Kelola Modul - " + Model.Title;
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id">← @Model.Title</a>
        <h1>Kelola Modul</h1>
        <p class="text-muted">@Model.Modules.Count modul · Drag untuk ubah urutan</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem">
    <div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
        <a asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-primary">+ Tambah Modul</a>
    </div>

    @if (!Model.Modules.Any())
    {
        <div class="empty-state">
            <p>Belum ada modul. Tambahkan materi pertama!</p>
            <a asp-action="Create" asp-route-courseId="@Model.Id" class="btn btn-primary">Tambah Modul</a>
        </div>
    }
    else
    {
        <div id="module-sortable">
            @foreach (var module in Model.Modules.OrderBy(m => m.Order))
            {
                <div class="module-manage-card" data-id="@module.Id">
                    <div class="module-drag-handle" title="Drag untuk ubah urutan">⠿</div>

                    <div class="module-manage-icon">
                        @if (module.ContentType == ModuleContentType.Video) { <span>🎬</span> }
                        else if (module.ContentType == ModuleContentType.Mixed) { <span>📖🎬</span> }
                        else { <span>📖</span> }
                    </div>

                    <div class="module-manage-info">
                        <div style="display:flex;align-items:center;gap:.5rem;flex-wrap:wrap">
                            <span class="module-order-num">@module.Order</span>
                            <h4>@module.Title</h4>
                            @if (!module.IsPublished)
                            {
                                <span class="badge badge-warning">Draft</span>
                            }
                            @if (module.DurationMinutes.HasValue)
                            {
                                <span class="text-muted" style="font-size:.8rem">⏱ @module.DurationMinutes mnt</span>
                            }
                        </div>
                        @if (module.Attachments.Any())
                        {
                            <p class="text-muted" style="font-size:.82rem;margin-top:.25rem">
                                📎 @module.Attachments.Count lampiran
                            </p>
                        }
                    </div>

                    <div class="module-manage-actions">
                        <a asp-action="Edit" asp-route-id="@module.Id" class="btn btn-outline btn-sm">Edit</a>
                        <a asp-action="View" asp-route-id="@module.Id" class="btn btn-outline btn-sm" target="_blank">Preview</a>
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Hapus modul ini?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@module.Id" />
                            <button class="btn btn-sm" style="background:#ef4444;color:white;border-color:#ef4444">Hapus</button>
                        </form>
                    </div>
                </div>
            }
        </div>
        <p class="text-muted" style="font-size:.82rem;margin-top:1rem;text-align:center">
            Drag kartu untuk mengubah urutan modul. Perubahan urutan disimpan otomatis.
        </p>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
const list = document.getElementById('module-sortable');
if (list) {
    Sortable.create(list, {
        handle: '.module-drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        onEnd: async () => {
            const ids = [...list.querySelectorAll('[data-id]')].map(el => parseInt(el.dataset.id));
            await fetch('/Module/Reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' },
                body: JSON.stringify(ids)
            });
            // Update nomor urutan
            list.querySelectorAll('.module-order-num').forEach((el, i) => el.textContent = i + 1);
        }
    });
}
</script>
@Html.AntiForgeryToken()
}
