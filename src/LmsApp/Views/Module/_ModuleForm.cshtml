@model (LmsApp.ViewModels.ModuleCreateViewModel Vm, bool IsEdit, LmsApp.Models.Course Course)
@{
    var vm = Model.Vm;
    var isEdit = Model.IsEdit;
    var course = Model.Course;
    var moduleObj = ViewBag.Module as LmsApp.Models.CourseModule;
}

<section class="page-header">
    <div class="container">
        <a asp-action="Manage" asp-controller="Module" asp-route-courseId="@course.Id">← Kelola Modul</a>
        <h1>@(isEdit ? "Edit Modul" : "Tambah Modul Baru")</h1>
        <p class="text-muted">@course.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem">
    <form asp-action="@(isEdit ? "Edit" : "Create")"
          asp-route-id="@(isEdit ? moduleObj?.Id.ToString() : null)"
          method="post" enctype="multipart/form-data"
          id="module-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Vm.CourseId" name="CourseId" />

        <div style="display:grid;grid-template-columns:1fr 320px;gap:2rem;align-items:start">

            <!-- Main Content -->
            <div>
                <div class="form-group">
                    <label class="form-label">Judul Modul</label>
                    <input asp-for="Vm.Title" name="Title" class="form-control"
                           placeholder="Contoh: Pengenalan MVC Pattern" />
                    <span asp-validation-for="Vm.Title" class="text-danger"></span>
                </div>

                <!-- Rich Text Editor -->
                <div class="form-group">
                    <label class="form-label">Konten Materi</label>
                    <div id="quill-editor" style="min-height:300px;background:white;border:1px solid var(--border);border-radius:0 0 8px 8px"></div>
                    <input type="hidden" name="Content" id="content-input" value="@vm.Content" />
                </div>

                <!-- Video URL -->
                <div class="form-group">
                    <label class="form-label">Link Video <small class="text-muted">(YouTube / Vimeo — opsional)</small></label>
                    <input asp-for="Vm.VideoUrl" name="VideoUrl" class="form-control"
                           placeholder="https://youtube.com/watch?v=..." id="video-url-input" />
                    <span asp-validation-for="Vm.VideoUrl" class="text-danger"></span>
                    <div id="video-preview" style="margin-top:.75rem;display:none">
                        <div class="video-embed-preview">
                            <iframe id="video-iframe" src="" allowfullscreen></iframe>
                        </div>
                    </div>
                </div>

                <!-- File Attachments -->
                <div class="form-group">
                    <label class="form-label">Lampiran <small class="text-muted">(PDF, PPT, DOC, ZIP · maks 50MB/file)</small></label>
                    <div class="file-upload-area" onclick="document.getElementById('att-input').click()">
                        <input type="file" name="attachments" id="att-input" multiple
                               accept=".pdf,.doc,.docx,.pptx,.xlsx,.zip,.png,.jpg"
                               style="display:none" onchange="showAttachments(this)" />
                        <p style="font-size:1.5rem">📎</p>
                        <p id="att-label">Klik atau drag file ke sini</p>
                    </div>
                    <div id="att-list" style="margin-top:.5rem"></div>

                    @if (moduleObj?.Attachments.Any() == true)
                    {
                        <div style="margin-top:.75rem">
                            <p class="text-muted" style="font-size:.85rem;font-weight:600">Lampiran tersimpan:</p>
                            @foreach (var att in moduleObj.Attachments)
                            {
                                <div style="display:flex;align-items:center;gap:.75rem;padding:.5rem;background:white;border:1px solid var(--border);border-radius:8px;margin-bottom:.35rem">
                                    <span>@(att.FileType == ".pdf" ? "📄" : att.FileType is ".doc" or ".docx" ? "📝" : att.FileType == ".pptx" ? "📊" : "📎")</span>
                                    <a href="@att.FileUrl" target="_blank" style="flex:1;font-size:.85rem">@att.FileName</a>
                                    <span class="text-muted" style="font-size:.75rem">@((att.FileSizeBytes / 1024.0).ToString("F0")) KB</span>
                                    <form asp-action="DeleteAttachment" method="post" style="margin:0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@att.Id" />
                                        <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border:none;padding:.25rem .5rem">✕</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Sidebar Settings -->
            <div>
                <div class="sidebar-card">
                    <h3 style="font-size:1rem;font-weight:700;margin-bottom:1rem">Pengaturan Modul</h3>

                    <div class="form-group">
                        <label class="form-label">Estimasi Durasi (menit)</label>
                        <input asp-for="Vm.DurationMinutes" name="DurationMinutes"
                               type="number" class="form-control" placeholder="30" min="1" max="600" />
                    </div>

                    <div class="form-group">
                        <label class="form-check">
                            <input asp-for="Vm.IsPublished" name="IsPublished" type="checkbox" class="form-check-input" />
                            <span class="form-label" style="margin:0">Publikasikan modul</span>
                        </label>
                        <p class="text-muted" style="font-size:.8rem;margin-top:.25rem">
                            Jika tidak dicentang, modul hanya terlihat oleh instruktur.
                        </p>
                    </div>

                    <div class="form-actions" style="flex-direction:column;gap:.5rem">
                        <button type="submit" class="btn btn-primary btn-block">
                            @(isEdit ? "Simpan Perubahan" : "Tambah Modul")
                        </button>
                        <a asp-action="Manage" asp-controller="Module" asp-route-courseId="@course.Id"
                           class="btn btn-outline btn-block">Batal</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<!-- Quill Rich Text Editor -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<script>
// ── Quill Editor ──────────────────────────────────────────────────
const quill = new Quill('#quill-editor', {
    theme: 'snow',
    placeholder: 'Tulis materi kursus di sini...',
    modules: {
        toolbar: [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
            [{ 'indent': '-1' }, { 'indent': '+1' }],
            ['blockquote', 'code-block'],
            ['link', 'image'],
            ['clean']
        ]
    }
});

// Load existing content
const existingContent = document.getElementById('content-input').value;
if (existingContent) quill.root.innerHTML = existingContent;

// Sync to hidden input before submit
document.getElementById('module-form').addEventListener('submit', () => {
    document.getElementById('content-input').value = quill.root.innerHTML;
});

// ── Video URL Preview ─────────────────────────────────────────────
const videoInput = document.getElementById('video-url-input');
const videoPreview = document.getElementById('video-preview');
const videoIframe = document.getElementById('video-iframe');

function parseVideoUrl(url) {
    const yt = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
    if (yt) return `https://www.youtube.com/embed/${yt[1]}?rel=0`;
    const vimeo = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
    if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
    return null;
}

videoInput?.addEventListener('input', () => {
    const embedUrl = parseVideoUrl(videoInput.value);
    if (embedUrl) {
        videoIframe.src = embedUrl;
        videoPreview.style.display = 'block';
    } else {
        videoPreview.style.display = 'none';
        videoIframe.src = '';
    }
});

// Show preview for existing video
if (videoInput?.value) videoInput.dispatchEvent(new Event('input'));

// ── Attachment list preview ───────────────────────────────────────
function showAttachments(input) {
    const list = document.getElementById('att-list');
    list.innerHTML = '';
    [...input.files].forEach(f => {
        const div = document.createElement('div');
        div.style.cssText = 'padding:.35rem .5rem;font-size:.85rem;color:var(--text-muted)';
        div.textContent = `📎 ${f.name} (${(f.size / 1024).toFixed(0)} KB)`;
        list.appendChild(div);
    });
    document.getElementById('att-label').textContent = `${input.files.length} file dipilih`;
}
</script>
}
