@{
    var assignment = ViewBag.Assignment as Assignment;
    var existing = ViewBag.Existing as Submission;
    ViewData["Title"] = "Kumpulkan Tugas";
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@assignment!.CourseId">← @assignment.Course.Title</a>
        <h1>@assignment.Title</h1>
        @if (assignment.DueDate.HasValue)
        {
            var isLate = DateTime.UtcNow > assignment.DueDate.Value;
            <p class="@(isLate ? "text-danger" : "text-muted")">
                Tenggat: @assignment.DueDate.Value.ToString("dd MMM yyyy, HH:mm")
                @if (isLate) { <strong>(Terlambat)</strong> }
            </p>
        }
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem">
    <div class="form-card" style="max-width:700px">
        @if (existing is not null)
        {
            <div class="alert alert-success">
                ✓ Sudah dikumpulkan pada @existing.SubmittedAt.ToString("dd MMM yyyy, HH:mm").
                Kamu bisa mengumpulkan ulang di bawah.
            </div>
        }

        <p style="margin-bottom:1.5rem;color:var(--text-muted)">@assignment.Description</p>

        <form asp-action="Submit" asp-controller="Submission" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="assignmentId" value="@assignment.Id" />

            <div class="form-group">
                <label class="form-label">Jawaban / Keterangan</label>
                <textarea name="content" class="form-control" rows="6"
                          placeholder="Tulis jawaban atau keterangan tambahan...">@existing?.Content</textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Upload File <small class="text-muted">(PDF, DOC, ZIP, gambar · maks 10MB)</small></label>
                <div class="file-upload-area" id="upload-area">
                    <input type="file" name="file" id="file-input" accept=".pdf,.doc,.docx,.zip,.png,.jpg,.jpeg"
                           style="display:none" onchange="showFileName(this)" />
                    <div onclick="document.getElementById('file-input').click()" style="cursor:pointer">
                        <p style="font-size:2rem">📎</p>
                        <p id="file-label">Klik untuk pilih file atau drag & drop</p>
                    </div>
                </div>
                @if (existing?.FileUrl is not null)
                {
                    <p class="text-muted" style="margin-top:.5rem;font-size:.85rem">
                        File sebelumnya: <a href="@existing.FileUrl" target="_blank">lihat file</a>
                    </p>
                }
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg">
                    @(existing is null ? "Kumpulkan Tugas" : "Kumpulkan Ulang")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function showFileName(input) {
    if (input.files[0]) {
        document.getElementById('file-label').textContent = input.files[0].name;
        document.getElementById('upload-area').style.borderColor = 'var(--primary)';
    }
}
const area = document.getElementById('upload-area');
area.addEventListener('dragover', e => { e.preventDefault(); area.style.borderColor = 'var(--primary)'; });
area.addEventListener('dragleave', () => { area.style.borderColor = 'var(--border)'; });
area.addEventListener('drop', e => {
    e.preventDefault();
    const input = document.getElementById('file-input');
    input.files = e.dataTransfer.files;
    showFileName(input);
});
</script>
}
