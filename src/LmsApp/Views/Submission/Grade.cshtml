@model Assignment
@{
    ViewData["Title"] = "Nilai Tugas - " + Model.Title;
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.CourseId">← @Model.Course.Title</a>
        <h1>Nilai Tugas: @Model.Title</h1>
        <p class="text-muted">@Model.Submissions.Count submission diterima</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem">
    @if (!Model.Submissions.Any())
    {
        <div class="empty-state"><p>Belum ada yang mengumpulkan tugas ini.</p></div>
    }
    else
    {
        @foreach (var sub in Model.Submissions.OrderBy(s => s.SubmittedAt))
        {
            <div class="submission-grade-card">
                <div class="submission-info">
                    <h4>@sub.UserName</h4>
                    <p class="text-muted" style="font-size:.85rem">
                        Dikumpulkan: @sub.SubmittedAt.ToString("dd MMM yyyy, HH:mm")
                        @if (Model.DueDate.HasValue && sub.SubmittedAt > Model.DueDate.Value)
                        {
                            <span style="color:var(--danger);font-weight:700"> · Terlambat</span>
                        }
                    </p>
                    @if (!string.IsNullOrEmpty(sub.Content))
                    {
                        <div class="submission-content">@sub.Content</div>
                    }
                    @if (sub.FileUrl is not null)
                    {
                        <a href="@sub.FileUrl" target="_blank" class="btn btn-outline btn-sm" style="margin-top:.5rem">
                            📎 Lihat File
                        </a>
                    }
                </div>
                <div class="submission-grade-form">
                    @if (sub.Score is not null)
                    {
                        <div style="text-align:center;margin-bottom:.75rem">
                            <span style="font-size:2rem;font-weight:800;color:var(--primary)">@sub.Score</span>
                            <span style="color:var(--text-muted)"> / @Model.MaxScore</span>
                        </div>
                    }
                    <form asp-action="GradeOne" asp-controller="Submission" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="submissionId" value="@sub.Id" />
                        <div class="form-group">
                            <label class="form-label">Nilai (0–@Model.MaxScore)</label>
                            <input type="number" name="score" class="form-control"
                                   value="@(sub.Score ?? 0)" min="0" max="@Model.MaxScore" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Feedback</label>
                            <textarea name="feedback" class="form-control" rows="2"
                                      placeholder="Komentar untuk peserta...">@sub.Feedback</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm" style="width:100%">
                            @(sub.Score is null ? "Beri Nilai" : "Update Nilai")
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>
