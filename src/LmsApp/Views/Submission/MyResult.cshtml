@model Submission
@{
    ViewData["Title"] = "Hasil Tugas - " + Model.Assignment.Title;
    double percentage = Model.Score.HasValue ? (double)Model.Score.Value / Model.Assignment.MaxScore * 100 : 0;
    string grade = percentage >= 85 ? "A" : percentage >= 75 ? "B" : percentage >= 65 ? "C" : percentage >= 55 ? "D" : "E";
    string gradeColor = percentage >= 75 ? "var(--success)" : percentage >= 55 ? "var(--warning)" : "var(--danger)";
}

<section class="page-header">
    <div class="container">
        <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Assignment.CourseId">
            ← @Model.Assignment.Course.Title
        </a>
        <h1>Hasil Tugas</h1>
        <p class="text-muted">@Model.Assignment.Title</p>
    </div>
</section>

<div class="container" style="padding:2rem 1.5rem;max-width:700px">

    @if (Model.Score.HasValue)
    {
        <!-- Score Card -->
        <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:2.5rem;text-align:center;margin-bottom:1.5rem;box-shadow:var(--shadow)">
            <div style="font-size:4rem;font-weight:900;color:@gradeColor;line-height:1">@Model.Score</div>
            <div style="color:var(--text-muted);font-size:1.1rem;margin:.25rem 0">dari @Model.Assignment.MaxScore poin</div>
            <div style="margin:.75rem 0">
                <span style="font-size:2rem;font-weight:700;background:@gradeColor;color:white;padding:.25rem .75rem;border-radius:8px">@grade</span>
            </div>

            <!-- Progress bar -->
            <div style="background:var(--border);border-radius:99px;height:12px;margin:1rem auto;max-width:300px">
                <div style="background:@gradeColor;height:100%;border-radius:99px;width:@(percentage.ToString("F0"))%;transition:width .5s"></div>
            </div>
            <div style="color:var(--text-muted);font-size:.9rem">@percentage.ToString("F0")% dari nilai maksimum</div>

            <div style="color:var(--text-muted);font-size:.8rem;margin-top:.75rem">
                Dinilai: @Model.GradedAt?.ToString("dd MMM yyyy, HH:mm")
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Feedback))
        {
            <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:12px;padding:1.5rem;margin-bottom:1.5rem">
                <h4 style="font-size:.95rem;color:#15803d;margin-bottom:.5rem">💬 Feedback Instruktur</h4>
                <p style="color:var(--text);line-height:1.65;white-space:pre-wrap">@Model.Feedback</p>
            </div>
        }
    }
    else
    {
        <div class="alert" style="background:#fef3c7;border:1px solid #fbbf24;border-radius:12px;padding:1.25rem">
            ⏳ Tugasmu sudah dikumpulkan dan sedang menunggu penilaian dari instruktur.
        </div>
    }

    <!-- Submission Detail -->
    <div style="background:var(--white);border:1px solid var(--border);border-radius:12px;padding:1.5rem">
        <h3 style="font-size:1rem;font-weight:700;margin-bottom:1rem">Detail Pengumpulan</h3>

        <div style="display:flex;gap:.5rem;margin-bottom:.75rem">
            <span class="text-muted" style="font-size:.85rem;min-width:120px">Dikumpulkan:</span>
            <span style="font-size:.85rem">@Model.SubmittedAt.ToString("dd MMM yyyy, HH:mm")</span>
        </div>

        @if (Model.Assignment.DueDate.HasValue)
        {
            bool isLate = Model.SubmittedAt > Model.Assignment.DueDate.Value;
            <div style="display:flex;gap:.5rem;margin-bottom:.75rem">
                <span class="text-muted" style="font-size:.85rem;min-width:120px">Tenggat:</span>
                <span style="font-size:.85rem;color:@(isLate ? "var(--danger)" : "inherit")">
                    @Model.Assignment.DueDate.Value.ToString("dd MMM yyyy, HH:mm")
                    @if (isLate) { <strong> (Terlambat)</strong> }
                </span>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Content))
        {
            <div style="margin-top:1rem">
                <p class="text-muted" style="font-size:.85rem;font-weight:600;margin-bottom:.35rem">Jawaban:</p>
                <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;font-size:.9rem;white-space:pre-wrap;line-height:1.65">@Model.Content</div>
            </div>
        }

        @if (Model.FileUrl is not null)
        {
            <div style="margin-top:.75rem">
                <a href="@Model.FileUrl" target="_blank" class="btn btn-outline btn-sm">📎 Lihat File yang Dikumpulkan</a>
            </div>
        }
    </div>

    <div style="margin-top:1.5rem">
        <a asp-controller="Submission" asp-action="Submit" asp-route-assignmentId="@Model.AssignmentId" class="btn btn-outline">
            ↺ Kumpulkan Ulang
        </a>
    </div>
</div>
