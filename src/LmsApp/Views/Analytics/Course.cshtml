@using LmsApp.Models
@{
    var course = ViewBag.Course as Course;
    ViewData["Title"] = "Analitik: " + course?.Title;

    var enrollByMonth = ViewBag.EnrollmentByMonth as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var progressList  = ViewBag.ProgressList    as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var quizStats     = ViewBag.QuizStats       as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var assignStats   = ViewBag.AssignmentStats as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var topPerformers = ViewBag.TopPerformers   as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    double avgRating     = (double)(ViewBag.AvgRating ?? 0.0);
    double completionRate = (double)(ViewBag.CompletionRate ?? 0.0);

    var monthLabels = enrollByMonth.Select(e => {
        var dt = new DateTime((int)e.Year, (int)e.Month, 1);
        return dt.ToString("MMM yy");
    }).ToList();
    var monthCounts = enrollByMonth.Select(e => (int)e.Count).ToList();
}

<section class="page-header">
    <div class="container" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem">
        <div>
            <h1>📊 Analitik Kursus</h1>
            <p class="text-muted">@course?.Title</p>
        </div>
        <a asp-controller="Course" asp-action="Details" asp-route-id="@course?.Id" class="btn btn-outline">← Kembali</a>
    </div>
</section>

<section class="analytics-section">
    <div class="container">

        <!-- KPI Cards -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-icon">👥</div>
                <div class="kpi-value">@course?.Enrollments.Count</div>
                <div class="kpi-label">Total Peserta</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">✅</div>
                <div class="kpi-value">@completionRate%</div>
                <div class="kpi-label">Tingkat Penyelesaian</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">⭐</div>
                <div class="kpi-value">@(avgRating > 0 ? avgRating.ToString("0.0") : "–")</div>
                <div class="kpi-label">Rata-rata Rating</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">📝</div>
                <div class="kpi-value">@course?.Modules.Count</div>
                <div class="kpi-label">Total Modul</div>
            </div>
        </div>

        <!-- Enrollment Chart -->
        <div class="analytics-card">
            <h3>Pendaftaran 6 Bulan Terakhir</h3>
            @if (!monthLabels.Any())
            {
                <p class="text-muted">Belum ada pendaftaran dalam 6 bulan terakhir.</p>
            }
            else
            {
                <div style="position:relative;height:250px">
                    <canvas id="enrollChart"></canvas>
                </div>
            }
        </div>

        <div class="analytics-row">
            <!-- Top Performers -->
            <div class="analytics-card">
                <h3>🏆 Top Performers</h3>
                @if (!topPerformers.Any())
                {
                    <p class="text-muted">Belum ada data progress.</p>
                }
                else
                {
                    <div class="performer-list">
                        @{int rank = 1;}
                        @foreach (var p in topPerformers)
                        {
                            <div class="performer-row">
                                <span class="performer-rank">#@rank</span>
                                <div class="performer-info">
                                    <span class="performer-name">@p.UserId</span>
                                    <div class="progress-bar-wrap">
                                        <div class="progress-bar-fill" style="width:@p.Percentage%"></div>
                                    </div>
                                </div>
                                <span class="performer-pct">@p.Percentage%</span>
                            </div>
                            rank++;
                        }
                    </div>
                }
            </div>

            <!-- Quiz Stats -->
            @if (quizStats.Any())
            {
                <div class="analytics-card">
                    <h3>📋 Statistik Quiz</h3>
                    <table class="analytics-table">
                        <thead>
                            <tr><th>Quiz</th><th>Attempt</th><th>Avg Score</th><th>Pass Rate</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var q in quizStats)
                            {
                                <tr>
                                    <td>@q.Title</td>
                                    <td>@q.AttemptCount</td>
                                    <td>@q.AvgScore%</td>
                                    <td>
                                        <span class="badge @(q.PassRate >= 70 ? "badge-success" : "badge-warning")">
                                            @q.PassRate%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Assignment Stats -->
        @if (assignStats.Any())
        {
            <div class="analytics-card">
                <h3>📤 Statistik Tugas</h3>
                <table class="analytics-table">
                    <thead>
                        <tr><th>Tugas</th><th>Submission</th><th>Dinilai</th><th>Avg Nilai</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in assignStats)
                        {
                            <tr>
                                <td>@a.Title</td>
                                <td>@a.SubmissionCount</td>
                                <td>@a.GradedCount</td>
                                <td>@(a.AvgScore > 0 ? a.AvgScore.ToString("0.0") : "–")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthLabels));
    var counts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(monthCounts));
    if (!labels.length) return;
    var ctx = document.getElementById('enrollChart');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Pendaftaran',
                data: counts,
                backgroundColor: 'rgba(99,102,241,0.7)',
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
    });
})();
</script>
}
