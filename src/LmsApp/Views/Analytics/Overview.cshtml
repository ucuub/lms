@{
    ViewData["Title"] = "Analytics Overview";
    var topCourses     = ViewBag.TopCourses      as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var enrollTrend    = ViewBag.EnrollmentTrend as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var topInstructors = ViewBag.TopInstructors  as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();

    var trendLabels = enrollTrend.Select(e => {
        var dt = new DateTime((int)e.Year, (int)e.Month, 1);
        return dt.ToString("MMM yy");
    }).ToList();
    var trendCounts = enrollTrend.Select(e => (int)e.Count).ToList();
}

<section class="page-header">
    <div class="container">
        <h1>📊 Platform Overview</h1>
        <p class="text-muted">Statistik keseluruhan platform LMS</p>
    </div>
</section>

<section class="analytics-section">
    <div class="container">

        <!-- KPI Cards -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-icon">👤</div>
                <div class="kpi-value">@ViewBag.TotalUsers</div>
                <div class="kpi-label">Total Pengguna</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">📚</div>
                <div class="kpi-value">@ViewBag.TotalCourses</div>
                <div class="kpi-label">Kursus Aktif</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">🎓</div>
                <div class="kpi-value">@ViewBag.TotalEnrollments</div>
                <div class="kpi-label">Total Pendaftaran</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">✅</div>
                <div class="kpi-value">@ViewBag.TotalCompletions</div>
                <div class="kpi-label">Penyelesaian</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">📝</div>
                <div class="kpi-value">@ViewBag.TotalQuizAttempts</div>
                <div class="kpi-label">Quiz Attempt</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">📤</div>
                <div class="kpi-value">@ViewBag.TotalSubmissions</div>
                <div class="kpi-label">Tugas Dikumpulkan</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon">🏆</div>
                <div class="kpi-value">@ViewBag.TotalCertificates</div>
                <div class="kpi-label">Sertifikat Diterbitkan</div>
            </div>
        </div>

        <!-- Enrollment Trend Chart -->
        <div class="analytics-card">
            <h3>Tren Pendaftaran 12 Bulan</h3>
            @if (!trendLabels.Any())
            {
                <p class="text-muted">Belum ada data pendaftaran.</p>
            }
            else
            {
                <div style="position:relative;height:260px">
                    <canvas id="trendChart"></canvas>
                </div>
            }
        </div>

        <div class="analytics-row">
            <!-- Top Courses -->
            <div class="analytics-card">
                <h3>🔥 Top 10 Kursus</h3>
                @if (!topCourses.Any())
                {
                    <p class="text-muted">Belum ada data kursus.</p>
                }
                else
                {
                    <table class="analytics-table">
                        <thead>
                            <tr><th>#</th><th>Kursus</th><th>Instruktur</th><th>Peserta</th><th>Rating</th></tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var c in topCourses)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>
                                        <a asp-controller="Analytics" asp-action="Course" asp-route-id="@c.Id"
                                           style="color:var(--primary);text-decoration:none;font-weight:500">@c.Title</a>
                                    </td>
                                    <td>@c.InstructorName</td>
                                    <td>@c.EnrollCount</td>
                                    <td>
                                        @if (c.AvgRating > 0)
                                        {
                                            <span>@(((double)c.AvgRating).ToString("0.0")) ⭐</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">–</span>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                }
            </div>

            <!-- Top Instructors -->
            <div class="analytics-card">
                <h3>👨‍🏫 Top Instruktur</h3>
                @if (!topInstructors.Any())
                {
                    <p class="text-muted">Belum ada data instruktur.</p>
                }
                else
                {
                    <div class="performer-list">
                        @{ int r = 1; }
                        @foreach (var instr in topInstructors)
                        {
                            <div class="performer-row">
                                <span class="performer-rank">#@r</span>
                                <div class="performer-info">
                                    <span class="performer-name">@instr.InstructorName</span>
                                    <span class="text-muted" style="font-size:.78rem">@instr.CourseCount kursus · @instr.TotalEnroll peserta</span>
                                </div>
                            </div>
                            r++;
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(trendLabels));
    var counts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(trendCounts));
    if (!labels.length) return;
    var ctx = document.getElementById('trendChart');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Pendaftaran',
                data: counts,
                borderColor: 'rgb(99,102,241)',
                backgroundColor: 'rgba(99,102,241,0.12)',
                fill: true,
                tension: 0.4,
                pointRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
    });
})();
</script>
}
