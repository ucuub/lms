@model IEnumerable<Course>
@{
    ViewData["Title"] = "Admin Panel";
}

<section class="page-header">
    <div class="container">
        <h1>⚙️ Admin Panel</h1>
    </div>
</section>

<div class="container" style="padding: 2rem 1.5rem;">
    <div class="stats-grid" style="margin-bottom:2rem">
        <div class="stat-card"><h2>@ViewBag.TotalCourses</h2><p>Total Kursus</p></div>
        <div class="stat-card"><h2>@ViewBag.TotalEnrollments</h2><p>Total Pendaftaran</p></div>
        <div class="stat-card"><h2>@ViewBag.TotalQuizzes</h2><p>Total Quiz</p></div>
        <div class="stat-card"><h2>@ViewBag.TotalCertificates</h2><p>Sertifikat Diterbitkan</p></div>
    </div>

    <h2 class="section-title">Kursus Terbaru</h2>
    <div class="course-grid">
        @foreach (var course in Model)
        {
            <div class="course-card">
                <div class="course-card-body">
                    <h3>@course.Title</h3>
                    <p class="text-muted">@course.InstructorName</p>
                    <span class="badge @(course.IsPublished ? "badge-success" : "badge-warning")">
                        @(course.IsPublished ? "Dipublikasi" : "Draft")
                    </span>
                </div>
                <div class="course-card-footer">
                    <a asp-action="Courses" class="btn btn-outline btn-sm">Kelola</a>
                </div>
            </div>
        }
    </div>
</div>
