@model IEnumerable<Course>
@{
    ViewData["Title"] = "Kelola Kursus";
}

<section class="page-header">
    <div class="container">
        <a asp-action="Index">← Admin Panel</a>
        <h1>Kelola Kursus</h1>
    </div>
</section>

<div class="container" style="padding: 2rem 1.5rem;">
    <div class="grade-table-wrap">
        <table class="grade-table">
            <thead>
                <tr><th>Judul</th><th>Instruktur</th><th>Peserta</th><th>Status</th><th>Aksi</th></tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td><strong>@course.Title</strong></td>
                        <td>@course.InstructorName</td>
                        <td>@course.Enrollments.Count</td>
                        <td>
                            <span class="badge @(course.IsPublished ? "badge-success" : "badge-warning")">
                                @(course.IsPublished ? "Aktif" : "Draft")
                            </span>
                        </td>
                        <td style="display:flex; gap:0.5rem;">
                            <form asp-action="TogglePublish" asp-route-id="@course.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline btn-sm">
                                    @(course.IsPublished ? "Sembunyikan" : "Publikasikan")
                                </button>
                            </form>
                            <form asp-action="DeleteCourse" asp-route-id="@course.Id" method="post"
                                  onsubmit="return confirm('Hapus kursus ini?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm" style="background:#ef4444;color:white;border-color:#ef4444">Hapus</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
