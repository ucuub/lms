<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Pro</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                LMS Pro
            </a>
            <ul class="navbar-menu">
                <li><a asp-controller="Home" asp-action="Index">Beranda</a></li>
                <li><a asp-controller="Course" asp-action="Index">Kursus</a></li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                    <li><a asp-controller="Course" asp-action="MyCourses">Kursus Saya</a></li>
                    <li><a asp-controller="Calendar" asp-action="Index">📅</a></li>
                    <li class="notif-bell">
                        <a asp-controller="Notification" asp-action="Index" id="notif-bell-link">
                            🔔 <span id="notif-badge" class="notif-badge" style="display:none">0</span>
                        </a>
                    </li>
                    @if (User.IsInRole("instructor") || User.IsInRole("admin"))
                    {
                        <li><a asp-controller="Course" asp-action="Create">Buat Kursus</a></li>
                    }
                    @if (User.IsInRole("admin"))
                    {
                        <li><a asp-controller="Admin" asp-action="Index">⚙️ Admin</a></li>
                    }
                    <li class="navbar-user">
                        <span>Halo, @User.Identity.Name</span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline">Keluar</a>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="Login" class="btn btn-primary">Masuk</a></li>
                }
            </ul>
        </div>
    </nav>

    <!-- Alert Messages -->
    <div class="container" style="margin-top: 1rem;">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-error">@error</div>
        }
    </div>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; @DateTime.Now.Year LMS Pro. Semua hak dilindungi.</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
        // Poll notification count every 60s
        async function fetchNotifCount() {
            try {
                const r = await fetch('/Notification/Count');
                const d = await r.json();
                const badge = document.getElementById('notif-badge');
                if (badge) {
                    badge.textContent = d.count;
                    badge.style.display = d.count > 0 ? 'inline-flex' : 'none';
                }
            } catch {}
        }
        fetchNotifCount();
        setInterval(fetchNotifCount, 60000);
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
